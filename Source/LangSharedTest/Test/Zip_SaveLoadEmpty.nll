namespace NumbatLogic
{
	class Zip_SaveLoadEmpty
	{
        public static void Run()
		{
			// Step 1: Create an empty zip file
			Zip* pZip = own new Zip();
			Assert::Plz(pZip != null);
			
			// Step 2: Save the empty zip to a blob
			gsBlob* pSaveBlob = own new gsBlob();
			bool saveResult = pZip.Save(pSaveBlob);
			Assert::Plz(saveResult == true);
			
			// Step 3: Get checksum of the saved blob
			Uint8 saveChecksum = pSaveBlob.GetChecksum();
			
			// Step 4: Load the saved zip back
			Zip* pReloadedZip = own new Zip();
			Assert::Plz(pReloadedZip != null);
			
			// Ensure blob offset is at the start
			pSaveBlob.SetOffset(0);
			bool loadResult = pReloadedZip.Load(pSaveBlob);
			Assert::Plz(loadResult == true);
			
			// Step 5: Save the reloaded zip to another blob
			gsBlob* pReloadedSaveBlob = own new gsBlob();
			bool reloadedSaveResult = pReloadedZip.Save(pReloadedSaveBlob);
			Assert::Plz(reloadedSaveResult == true);
			
			// Step 6: Get checksum of the reloaded save blob
			Uint8 reloadedSaveChecksum = pReloadedSaveBlob.GetChecksum();
			
			// Step 7: Compare the checksum values - they should be identical
			Assert::Plz(saveChecksum == reloadedSaveChecksum);
			
			// Step 8: Verify both zips are empty
			int numFiles1 = pZip.GetNumFile();
			int numFiles2 = pReloadedZip.GetNumFile();
			Assert::Plz(numFiles1 == 0);
			Assert::Plz(numFiles2 == 0);
			Assert::Plz(numFiles1 == numFiles2);
		}
	}
} 